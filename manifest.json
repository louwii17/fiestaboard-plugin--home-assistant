{
  "id": "home_assistant",
  "name": "Home Assistant",
  "version": "1.3.0",
  "description": "Display Home Assistant entities and trigger priority-based FiestaBoard page overrides",
  "author": "FiestaBoard Team and contributors",
  "repository": "https://github.com/louwii17/fiestaboard-plugin--home-assistant",
  "documentation": "README.md",
  "icon": "home",
  "category": "home",
  "min_refresh_seconds": 10,
  "supports_triggers": true,
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable Home Assistant",
        "default": false
      },
      "base_url": {
        "type": "string",
        "title": "Home Assistant URL",
        "description": "Base URL (e.g., http://192.168.1.100:8123)",
        "format": "uri"
      },
      "access_token": {
        "type": "string",
        "title": "Long-Lived Access Token",
        "description": "Create in HA: Profile \u2192 Long-Lived Access Tokens",
        "ui:widget": "password"
      },
      "entities": {
        "type": "array",
        "title": "Entities to Monitor",
        "description": "Home Assistant entities to display",
        "items": {
          "type": "object",
          "properties": {
            "entity_id": {
              "type": "string",
              "title": "Entity ID",
              "description": "e.g., sensor.temperature, binary_sensor.door"
            },
            "name": {
              "type": "string",
              "title": "Display Name",
              "description": "Short name for display",
              "maxLength": 12
            }
          },
          "required": [
            "entity_id",
            "name"
          ]
        }
      },
      "timeout": {
        "type": "integer",
        "title": "Timeout (seconds)",
        "default": 5,
        "minimum": 1,
        "maximum": 30
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "default": 30,
        "minimum": 10
      },
      "trigger_rules": {
        "type": "array",
        "title": "Page trigger rules",
        "description": "Generic entity or attribute conditions that temporarily override lower-priority pages",
        "default": [],
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "title": "Rule ID",
              "description": "Stable lowercase identifier, such as now_playing or front_door",
              "pattern": "^[a-z][a-z0-9_-]{0,63}$"
            },
            "enabled": {
              "type": "boolean",
              "title": "Enabled",
              "default": true
            },
            "name": {
              "type": "string",
              "title": "Rule name",
              "description": "Short descriptive name exposed to the trigger page",
              "maxLength": 40
            },
            "entity_id": {
              "type": "string",
              "title": "Entity ID",
              "description": "Home Assistant entity, such as input_boolean.vestaboard_alert"
            },
            "page_id": {
              "type": "string",
              "title": "FiestaBoard page",
              "description": "Existing template page displayed while this rule is active",
              "ui:widget": "page-picker"
            },
            "field": {
              "type": "string",
              "title": "State or attribute",
              "description": "Use state, an attribute name, or a dot-separated nested attribute path",
              "default": "state"
            },
            "operator": {
              "type": "string",
              "title": "Comparison",
              "default": "equals",
              "enum": [
                "equals",
                "not_equals",
                "contains",
                "not_contains",
                "one_of",
                "greater_than",
                "greater_than_or_equal",
                "less_than",
                "less_than_or_equal",
                "exists",
                "not_exists",
                "changes",
                "changes_to"
              ],
              "enumNames": [
                "Equals",
                "Does not equal",
                "Contains",
                "Does not contain",
                "Is one of (comma-separated)",
                "Greater than",
                "Greater than or equal",
                "Less than",
                "Less than or equal",
                "Exists",
                "Does not exist",
                "Changes",
                "Changes to value"
              ]
            },
            "value": {
              "type": "string",
              "title": "Comparison value",
              "description": "Not required for Exists, Does not exist, or Changes"
            },
            "case_sensitive": {
              "type": "boolean",
              "title": "Case-sensitive comparison",
              "default": false
            },
            "priority": {
              "type": "integer",
              "title": "Priority",
              "description": "Higher values override lower triggers. Ambient 10, Notable 50, Urgent 80, Critical 100; MLB Scores uses 50",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            },
            "duration_seconds": {
              "type": "integer",
              "title": "Trigger lease (seconds)",
              "description": "How long the page remains after the last matching check; keep this longer than the refresh interval",
              "default": 45,
              "minimum": 10,
              "maximum": 900
            }
          },
          "required": ["id", "entity_id", "page_id", "operator"]
        }
      },
      "mqtt_statestream": {
        "type": "boolean",
        "title": "Enable MQTT Statestream",
        "description": "Subscribe to HA Statestream for real-time entity updates via MQTT instead of REST polling. Requires the MQTT Statestream integration in Home Assistant.",
        "default": false
      },
      "statestream_base_topic": {
        "type": "string",
        "title": "Statestream Base Topic",
        "description": "MQTT topic prefix used by HA Statestream (default: homeassistant/statestream)",
        "default": "homeassistant/statestream"
      },
      "statestream_broker_host": {
        "type": "string",
        "title": "MQTT Broker Host (optional)",
        "description": "Overrides MQTT_BROKER_HOST env var. Leave empty to use the system MQTT broker."
      },
      "statestream_broker_port": {
        "type": "integer",
        "title": "MQTT Broker Port (optional)",
        "description": "Overrides MQTT_BROKER_PORT env var. Leave empty to use the system MQTT broker port.",
        "minimum": 1,
        "maximum": 65535
      }
    },
    "required": []
  },
  "env_vars": [
    {
      "name": "HOME_ASSISTANT_BASE_URL",
      "required": false,
      "description": "Home Assistant base URL (not required when using MQTT Statestream mode)"
    },
    {
      "name": "HOME_ASSISTANT_ACCESS_TOKEN",
      "required": false,
      "description": "Long-lived access token (not required when using MQTT Statestream mode)"
    },
    {
      "name": "HOME_ASSISTANT_TIMEOUT",
      "required": false,
      "description": "Request timeout in seconds",
      "default": "5"
    }
  ],
  "variables": {
    "groups": {
      "status": {
        "label": "Connection Status"
      }
    },
    "simple": {
      "connected": {
        "description": "Whether Home Assistant is connected",
        "type": "string",
        "max_length": 7,
        "group": "status",
        "example": "true"
      },
      "entity_count": {
        "description": "Number of monitored entities",
        "type": "number",
        "max_length": 5,
        "group": "status",
        "example": "12"
      },
      "data_source": {
        "description": "Data source method (rest or mqtt_statestream)",
        "type": "string",
        "max_length": 17,
        "group": "status",
        "example": "rest"
      },
      "trigger_active": {
        "description": "Whether the current template context came from an active trigger",
        "type": "boolean",
        "max_length": 5,
        "group": "status",
        "example": true
      },
      "trigger_rule_id": {
        "description": "Stable ID of the rule that fired",
        "type": "string",
        "max_length": 64,
        "group": "status",
        "example": "now_playing"
      },
      "trigger_name": {
        "description": "Configured name of the rule that fired",
        "type": "string",
        "max_length": 40,
        "group": "status",
        "example": "Front door alert"
      },
      "trigger_page_id": {
        "description": "FiestaBoard page selected by the active rule",
        "type": "string",
        "max_length": 80,
        "group": "status",
        "example": "page-home-alert"
      },
      "trigger_priority": {
        "description": "Numeric priority of the active rule",
        "type": "number",
        "max_length": 3,
        "group": "status",
        "example": "60"
      },
      "trigger_duration_seconds": {
        "description": "Configured trigger lease in seconds",
        "type": "number",
        "max_length": 3,
        "group": "status",
        "example": "45"
      },
      "trigger_entity_id": {
        "description": "Entity ID evaluated by the active rule",
        "type": "string",
        "max_length": 80,
        "group": "status",
        "example": "binary_sensor.front_door"
      },
      "trigger_field": {
        "description": "State or attribute field evaluated by the active rule",
        "type": "string",
        "max_length": 80,
        "group": "status",
        "example": "state"
      },
      "trigger_operator": {
        "description": "Comparison operator used by the active rule",
        "type": "string",
        "max_length": 24,
        "group": "status",
        "example": "equals"
      },
      "trigger_expected": {
        "description": "Configured comparison value",
        "type": "string",
        "max_length": 80,
        "group": "status",
        "example": "on"
      },
      "trigger_actual": {
        "description": "Actual entity value that fired the rule",
        "type": "string",
        "max_length": 80,
        "group": "status",
        "example": "on"
      },
      "trigger_previous": {
        "description": "Previous value for change-based rules",
        "type": "string",
        "max_length": 80,
        "group": "status",
        "example": "off"
      }
    },
    "dynamic_entities": {
      "description": "Access any Home Assistant entity dynamically",
      "access_pattern": "home_assistant.{entity_id}.state",
      "examples": [
        "home_assistant.sensor.temperature.state",
        "home_assistant.binary_sensor.door.state",
        "home_assistant.light.kitchen.state"
      ]
    }
  },
  "color_rules_schema": {
    "state": {
      "type": "match",
      "description": "Color based on entity state",
      "default_rules": [
        {
          "condition": "==",
          "value": "on",
          "color": "green"
        },
        {
          "condition": "==",
          "value": "off",
          "color": "red"
        },
        {
          "condition": "==",
          "value": "open",
          "color": "orange"
        },
        {
          "condition": "==",
          "value": "closed",
          "color": "green"
        },
        {
          "condition": "==",
          "value": "unavailable",
          "color": "red"
        }
      ]
    }
  },
  "fiestaboard_version": ">=7.0.0",
  "screenshots": [
    {
      "src": "docs/board-display.png",
      "alt": "Home Assistant displayed on a Vestaboard",
      "caption": "Display entity states from Home Assistant via REST API or MQTT Statestream",
      "primary": true
    }
  ],
  "demo": {
    "flagship": {
      "name": "Home Assistant Demo",
      "template": [
        "Home Assistant",
        "",
        "Connected {{home_assistant.connected}}",
        "Entities {{home_assistant.entity_count}}",
        "Via {{home_assistant.data_source}}",
        ""
      ],
      "line_metadata": [
        {
          "alignment": "center",
          "wrap": false
        },
        {
          "alignment": "center",
          "wrap": false
        },
        {
          "alignment": "center",
          "wrap": false
        },
        {
          "alignment": "center",
          "wrap": false
        },
        {
          "alignment": "center",
          "wrap": false
        },
        {
          "alignment": "center",
          "wrap": false
        }
      ]
    },
    "note": {
      "name": "Home Assistant (Note)",
      "template": [
        "HOME ASSISTANT",
        "{{home_assistant.entity_count}} ENTITIES",
        "{{home_assistant.data_source}}"
      ],
      "line_metadata": [
        {
          "alignment": "left",
          "wrap": false
        },
        {
          "alignment": "left",
          "wrap": false
        },
        {
          "alignment": "left",
          "wrap": false
        }
      ]
    }
  }
}
